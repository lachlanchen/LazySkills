# LazySkills local machine configuration.
#
# Copy this file to `.config/lazyskills.local.env`, edit the values for your
# machine, then run:
#
#   set -a
#   . .config/lazyskills.local.env
#   set +a
#
# Keep `.config/lazyskills.local.env` private. It is gitignored.

LAZYSKILLS_ROOT=/path/to/LazySkills
AGINTIFLOW_ROOT=/path/to/AgInTiFlow

LALACHAN_ROOT=/path/to/LALACHAN
LAZYEDIT_ROOT=/path/to/lazyedit
AUTOPUB_MONITOR_ROOT=/path/to/autopub-monitor
NUTSTORE_AUTOPUBLISH=/path/to/AutoPublish

XYQ_CDP_URL=http://127.0.0.1:9222
LAZYEDIT_STUDIO=http://127.0.0.1:18791/editor
LAZYEDIT_API=http://127.0.0.1:18787

AUTOPUBLISH_SSH=user@autopublish-host
AUTOPUBLISH_API=http://autopublish-host:8081/publish
AUTOPUBLISH_QUEUE_URL=http://autopublish-host:8081/publish/queue
AUTOPUBLISH_ROOT=/path/to/remote/autopub
